<Window x:Class="Komponenta2.Views.GlavniProzor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Komponenta 2 — Statistika konferencija" Height="650" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Gore: izbor perioda i preuzimanje -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
            <TextBlock Text="Od:" VerticalAlignment="Center" Margin="0,0,5,0" />
            <DatePicker SelectedDate="{Binding Od}" Width="130" Margin="0,0,15,0" />
            <TextBlock Text="Do:" VerticalAlignment="Center" Margin="0,0,5,0" />
            <DatePicker SelectedDate="{Binding Do}" Width="130" Margin="0,0,15,0" />
            <Button Content="Preuzmi" Command="{Binding KomandaPreuzmi}" Padding="15,3" Margin="0,0,15,0" />
            <TextBlock Text="{Binding StatusPoruka}" VerticalAlignment="Center" Foreground="DarkGreen" />
        </StackPanel>

        <!-- Sredina: prikaz preuzetih perioda i konferencija -->
        <GroupBox Grid.Row="1" Header="Preuzeti periodi">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding PrikazaniPeriodi}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="{Binding ZaglavljePerioda}" FontWeight="Bold" Margin="0,0,0,3" />
                                <ItemsControl ItemsSource="{Binding Konferencije}" Margin="15,0,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Linija}" FontFamily="Consolas" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </GroupBox>

        <!-- Dole: obrada statistike -->
        <GroupBox Grid.Row="2" Header="Statistička obrada" Margin="0,10,0,0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Period:" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <ComboBox ItemsSource="{Binding PrikazaniPeriodi}"
                              SelectedItem="{Binding IzabraniPeriod}"
                              DisplayMemberPath="ZaglavljePerioda"
                              Width="170" Margin="0,0,15,0" />
                    <TextBlock Text="Metoda:" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <ComboBox ItemsSource="{Binding DostupneMetode}"
                              SelectedItem="{Binding IzabranaMetoda}"
                              DisplayMemberPath="Naziv"
                              Width="250" Margin="0,0,15,0" />
                    <Button Content="Obradi" Command="{Binding KomandaObradi}" Padding="15,3" Margin="0,0,15,0" />
                    <Button Content="Izvezi CSV" Command="{Binding KomandaIzveziCsv}" Padding="15,3" />
                </StackPanel>
                <DataGrid IsReadOnly="True" AutoGenerateColumns="False"
                          ItemsSource="{Binding Rezultati}" Height="180">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Metoda" Binding="{Binding Metoda}" Width="*" />
                        <DataGridTextColumn Header="Period" Binding="{Binding Period}" Width="Auto" />
                        <DataGridTextColumn Header="Stavka" Binding="{Binding Stavka}" Width="*" />
                        <DataGridTextColumn Header="Vrednost" Binding="{Binding Vrednost}" Width="Auto" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
